#!/usr/bin/env bash
# Pre-commit hook: enforces the 300-line cap on staged non-test files,
# then runs `make test`. Installed via `make install-hooks`.
set -euo pipefail

MAX_LINES=300

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

mapfile -t staged < <(git diff --cached --name-only --diff-filter=ACMR)

is_excluded() {
	local path=$1
	case "$path" in
		*_test.go) return 0 ;;
		vendor/*|bin/*|testcases/*|.j/*) return 0 ;;
		*) return 1 ;;
	esac
}

violations=()
for path in "${staged[@]}"; do
	if is_excluded "$path"; then
		continue
	fi
	lines=$(git show ":$path" | wc -l | tr -d ' ')
	if [ "$lines" -gt "$MAX_LINES" ]; then
		violations+=("$path: $lines lines (limit $MAX_LINES)")
	fi
done

if [ ${#violations[@]} -gt 0 ]; then
	echo "pre-commit: staged non-test file(s) exceed ${MAX_LINES}-line cap:" >&2
	for v in "${violations[@]}"; do
		echo "  - $v" >&2
	done
	echo "split the file or move logic out before committing." >&2
	exit 1
fi

echo "pre-commit: running 'make test'..." >&2
if ! make test; then
	echo "pre-commit: 'make test' failed; commit aborted." >&2
	exit 1
fi
